---
const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-black/10 py-12">
  <svg
    aria-hidden="true"
    viewBox="0 0 1200 260"
    class="pointer-events-none absolute inset-x-0 -bottom-8 h-42 w-full text-slate-400 opacity-12"
  >
    <text
      x="50%"
      y="78%"
      text-anchor="middle"
      font-size="220"
      font-weight="800"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      letter-spacing="6"
    >
      Mirage
    </text>
  </svg>

  <div
    class="relative z-10 mx-auto flex max-w-7xl flex-col gap-4 px-4 sm:px-6 lg:px-8 md:flex-row md:items-center md:justify-between"
  >
    <a
      href="/"
      class="inline-flex items-center gap-2 font-display text-base font-bold text-slate-900"
    >
      <svg viewBox="0 0 32 32" aria-hidden="true" class="h-5 w-5 shrink-0">
        <path d="M5 24.5L9.1 8h3.8L8.8 24.5H5Z" fill="currentColor"></path>
        <path d="M12.2 24.5L16 11.5h3.7L16 24.5h-3.8Z" fill="currentColor"></path>
        <path d="M19.6 24.5L23.7 8H27l-4 16.5h-3.4Z" fill="currentColor"></path>
      </svg>
      <span>Mirage</span>
    </a>

    <p class="text-sm text-slate-600">© {currentYear} Mirage. All rights reserved.</p>
  </div>
</footer>
