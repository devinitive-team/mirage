---
import { BorderBeam } from "@/components/ui/border-beam";

interface Props {
  ctaHref: string;
}

const { ctaHref } = Astro.props;
---

<section id="top" class="mt-6">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="min-w-0">
      <p
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-slate-600"
      >
        <span aria-hidden="true" class="h-px w-2.5 bg-slate-400"></span>
        Ask any document. Verify every answer.
        <span aria-hidden="true" class="h-px w-2.5 bg-slate-400"></span>
      </p>

      <h1 class="mt-4 font-display text-4xl leading-tight sm:text-5xl lg:text-7xl">
        Find what matters across thousands of pages, with citations.
      </h1>

      <p class="mt-6 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">
        Mirage turns raw PDFs into semantic context so your team can ask in plain language and get
        answers tied to exact source pages.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={ctaHref}
          class="inline-flex h-11 items-center justify-center border border-slate-900 bg-slate-900 px-5 font-display text-sm font-bold text-white transition duration-150 ease-out hover:-translate-y-0.5 hover:bg-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-500"
          data-cta="try-for-free"
          data-cta-location="hero"
        >
          Try for free
        </a>

        <a
          href="#how-it-works"
          class="inline-flex h-11 items-center justify-center border border-black/20 bg-white px-5 font-display text-sm font-bold text-slate-900 transition duration-150 ease-out hover:-translate-y-0.5 hover:border-black/30 hover:bg-slate-50"
        >
          See how Mirage works
        </a>
      </div>

      <div
        class="group relative mx-auto mt-8 w-full max-w-7xl border border-black/10 bg-white p-1.5"
      >
        <div class="relative overflow-hidden border border-black/10">
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-12 top-0 h-px bg-black/20"></span>
          <img
            src="/hero.png"
            alt="Mirage product preview with cited answers and document context"
            class="h-auto w-full object-contain transition-transform duration-700 ease-out"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <BorderBeam
            client:load
            size={210}
            duration={7.5}
            borderWidth={2}
            colorFrom="#fff"
            colorTo="#000"
            className="opacity-60"
          />
        </div>
      </div>
    </div>
  </div>
</section>
