---
import { BorderBeam } from "@/components/ui/border-beam";
import EmailForm from "./email-form.astro";

interface Props {
  ctaHref: string;
}

const { ctaHref } = Astro.props;
---

<section id="top" class="mt-6">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="min-w-0">
      <p
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-slate-600"
      >
        <span aria-hidden="true" class="h-px w-2.5 bg-slate-400"></span>
        Ask any document. Verify every answer.
        <span aria-hidden="true" class="h-px w-2.5 bg-slate-400"></span>
      </p>

      <h1
        class="mt-4 font-display text-4xl leading-tight sm:text-5xl lg:text-7xl text-bold tracking-tighter text-slate-900 text-balance"
      >
        Find what matters across thousands of pages, with citations.
      </h1>

      <p class="mt-6 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">
        Mirage turns raw PDFs into semantic context so your team can ask in plain language and get
        answers tied to exact source pages.
      </p>

      <EmailForm />

      <div class="rounded-2xl border bg-white/50 p-3 border-black/10 mt-12">
        <img
          src="/hero-light.png"
          alt="Mirage product preview with cited answers and document context"
          class="border border-black/10 rounded-xl h-auto w-full object-contain transition-transform duration-700 ease-out"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
