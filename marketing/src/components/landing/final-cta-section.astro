---
import { InteractiveGridPattern } from "@/components/ui/interactive-grid-pattern";

interface Props {
  ctaHref: string;
}

const { ctaHref } = Astro.props;
---

<section class="mt-16" aria-label="Final conversion section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative isolate min-h-96 overflow-hidden px-4 py-14 text-center sm:px-8 sm:py-16">
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <InteractiveGridPattern
          client:load
          className="h-full w-full opacity-80"
          width={20}
          height={20}
          squares={[72, 24]}
          squaresClassName="hover:fill-cyan-300/40"
        />
      </div>

      <h2
        class="relative z-10 mx-auto mt-5 max-w-4xl font-display text-5xl font-extrabold leading-tight tracking-tight sm:text-6xl lg:text-7xl"
      >
        Ask once. Verify instantly. Move with confidence.
      </h2>

      <p class="relative z-10 mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-700">
        Keep your current document workflows and add Mirage as the semantic layer that returns
        cited, review-ready answers.
      </p>

      <a
        href={ctaHref}
        class="relative z-10 mt-8 inline-flex h-14 items-center justify-center border border-slate-900 bg-slate-900 px-8 font-display text-base font-extrabold text-white transition duration-150 ease-out hover:-translate-y-0.5 hover:bg-slate-800 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-cyan-500"
        data-cta="try-for-free"
        data-cta-location="footer"
      >
        Try for free
      </a>
    </div>
  </div>
</section>
