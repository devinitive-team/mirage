---
import { BlurFade } from "@/components/ui/blur-fade";
import EmailForm from "./email-form.astro";

interface Props {
  ctaHref: string;
}

const { ctaHref } = Astro.props;
---

<section class="relative isolate mt-16 overflow-hidden" aria-label="Final conversion section">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="mx-auto h-full max-w-5xl text-slate-700" style="opacity: 0.14;">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 500 500"
        width="100%"
        height="100%"
        class="h-full w-full"
        preserveAspectRatio="xMidYMid meet"
      >
        <defs>
          <style>
            .frame {
              stroke: currentColor;
              stroke-width: 0.5;
              fill: none;
              opacity: 0.3;
            }
            .bg-grid {
              stroke: currentColor;
              stroke-width: 0.5;
              stroke-dasharray: 2 6;
              opacity: 0.2;
            }
            .surface {
              fill: currentColor;
              opacity: 0.03;
            }
            .outline {
              fill: none;
              stroke: currentColor;
              stroke-width: 1.5;
              stroke-linejoin: round;
            }
            .outline-thin {
              fill: none;
              stroke: currentColor;
              stroke-width: 0.75;
              stroke-linejoin: round;
            }
            .doc-text {
              fill: none;
              stroke: currentColor;
              stroke-width: 1.25;
              stroke-linecap: round;
              opacity: 0.8;
            }
            .link-path {
              fill: none;
              stroke: currentColor;
              stroke-width: 1;
              stroke-dasharray: 4 4;
              opacity: 0.7;
            }
            .link-solid {
              fill: none;
              stroke: currentColor;
              stroke-width: 1;
              opacity: 0.7;
            }
            .node-outer {
              fill: var(--bg-color, #fff);
              stroke: currentColor;
              stroke-width: 1;
            }
            .node-inner {
              fill: currentColor;
            }
            .tech-text {
              font-family: monospace;
              font-size: 9px;
              fill: currentColor;
              opacity: 0.75;
              letter-spacing: 0.1em;
            }
            .cite-text {
              font-family: monospace;
              font-size: 7px;
              fill: currentColor;
              font-weight: bold;
            }
          </style>
        </defs>

        <g class="frame">
          <path d="M 40,60 L 40,40 L 60,40 M 460,60 L 460,40 L 440,40" />
          <path d="M 40,440 L 40,460 L 60,460 M 460,440 L 460,460 L 440,460" />
          <path d="M 250,20 L 250,40 M 250,460 L 250,480" />
          <path d="M 20,250 L 40,250 M 460,250 L 480,250" />
        </g>

        <g>
          <text x="40" y="80" class="tech-text">SYS_ID: M_MATRIX</text>
          <text x="40" y="95" class="tech-text">PROJ: ISO_DIM_3</text>
          <text x="40" y="110" class="tech-text">TILT: +30 DEG</text>
          <text x="370" y="425" class="tech-text">STATUS: OPTIMAL</text>
          <text x="370" y="440" class="tech-text">GRID_SNAP: ON</text>
        </g>

        <g class="bg-grid">
          <path
            d="M 250,184 L 70,274 M 286,202 L 106,292 M 322,220 L 142,310 M 358,238 L 178,328 M 394,256 L 214,346 M 430,274 L 250,364"
          />
          <path
            d="M 250,184 L 430,274 M 214,202 L 394,292 M 178,220 L 358,310 M 142,238 L 322,328 M 106,256 L 286,346 M 70,274 L 250,364"
          />

          <polygon
            points="250,220 142,274 250,328 358,274"
            fill="none"
            class="link-path"
            opacity="0.4"
          />
          <polygon
            points="250,170 142,224 250,278 358,224"
            fill="none"
            class="link-path"
            opacity="0.4"
          />
          <path
            d="M 250,220 L 250,170 M 142,274 L 142,224 M 250,328 L 250,278 M 358,274 L 358,224"
            class="link-path"
            opacity="0.4"
          />
        </g>

        <g class="m-shape">
          <polygon
            points="250,220 142,274 169,287.5 250,274 223,314.5 250,328 358,274 331,260.5 250,301 277,260.5 196,274 277,233.5"
            class="surface"
          />
          <polygon
            points="250,220 142,274 169,287.5 250,274 223,314.5 250,328 358,274 331,260.5 250,301 277,260.5 196,274 277,233.5"
            class="outline-thin"
            style="opacity: 0.4;"
          />

          <path
            d="M 331,210.5 L 331,260.5 M 250,251 L 250,301 M 277,210.5 L 277,260.5 M 196,224 L 196,274 M 277,183.5 L 277,233.5"
            class="outline-thin"
            style="opacity: 0.3;"
          />

          <path
            d="M 142,224 L 142,274 M 169,237.5 L 169,287.5 M 250,224 L 250,274 M 223,264.5 L 223,314.5 M 250,278 L 250,328 M 358,224 L 358,274 M 250,170 L 250,220"
            class="outline-thin"
          />

          <polygon
            points="250,170 142,224 169,237.5 250,224 223,264.5 250,278 358,224 331,210.5 250,251 277,210.5 196,224 277,183.5"
            class="outline"
            fill="var(--bg-color, #ffffff)"
          />
          <polygon
            points="250,170 142,224 169,237.5 250,224 223,264.5 250,278 358,224 331,210.5 250,251 277,210.5 196,224 277,183.5"
            class="surface"
          />
        </g>

        <g class="annotations">
          <path d="M 245,250 L 255,250 M 250,245 L 250,255" class="outline-thin" opacity="0.5" />
          <path
            d="M 142,224 L 135,224 M 142,217 L 142,231"
            class="outline-thin"
            opacity="0.3"
          />
          <path
            d="M 358,224 L 365,224 M 358,217 L 358,231"
            class="outline-thin"
            opacity="0.3"
          />

          <path d="M 250,224 L 250,120 L 280,120" class="link-path" />
          <circle cx="250" cy="224" r="3" class="node-outer" />
          <circle cx="250" cy="224" r="1" class="node-inner" />
          <circle cx="280" cy="120" r="2" class="node-inner" />
          <text x="285" y="123" class="tech-text">V_CORE_DIP</text>
          <text x="285" y="133" class="cite-text">[Z-INDEX: -1]</text>

          <path d="M 142,224 L 100,224 L 100,200" class="link-path" />
          <circle cx="142" cy="224" r="3" class="node-outer" />
          <circle cx="142" cy="224" r="1" class="node-inner" />
          <circle cx="100" cy="200" r="2" class="node-inner" />
          <text x="65" y="195" class="tech-text">EXT_L_01</text>

          <path d="M 358,224 L 400,224 L 400,200" class="link-path" />
          <circle cx="358" cy="224" r="3" class="node-outer" />
          <circle cx="358" cy="224" r="1" class="node-inner" />
          <circle cx="400" cy="200" r="2" class="node-inner" />
          <text x="385" y="195" class="tech-text">EXT_R_02</text>

          <path d="M 250,328 L 250,370 L 280,370" class="link-solid" />
          <polygon points="250,328 253,325 250,322 247,325" class="node-inner" />
          <circle cx="280" cy="370" r="2" class="node-inner" />
          <text x="285" y="373" class="tech-text">FRONT_ANCHOR</text>

          <path d="M 277,183.5 L 310,150 L 340,150" class="doc-text" />
          <circle cx="277" cy="183.5" r="1.5" class="node-inner" />
          <text x="345" y="153" class="tech-text">P_VECTOR_BACK</text>
        </g>
      </svg>
    </div>
  </div>
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="min-h-96 px-4 py-14 text-center sm:px-8 sm:py-16">
      <BlurFade client:visible direction="up" offset={10} duration={0.5} blur="5px">
        <h2
          class="mx-auto mt-5 max-w-4xl font-display text-5xl font-extrabold leading-tight tracking-tight sm:text-6xl lg:text-7xl"
        >
          Ask once. Verify instantly. Move with confidence.
        </h2>
      </BlurFade>

      <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.06}>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-700">
          Keep your current document workflows and add Mirage as the semantic layer that returns
          cited, review-ready answers.
        </p>
      </BlurFade>

      <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.12}>
        <div class="final-cta-form mx-auto mt-10 w-full max-w-3xl">
          <EmailForm />
        </div>
      </BlurFade>
    </div>
  </div>
</section>

<style>
  .final-cta-form :global(form[data-uid="121137e280"]) {
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
  }
  .final-cta-form :global(.formkit-fields) {
    justify-content: center;
  }
</style>
