---
import { waitlistApiUrl } from "@/config/site";

const successMessage = "Thanks! You're on the waitlist.";
const genericErrorMessage = "We couldn't save your email right now. Please try again.";
---

<div class="waitlist-form-wrap" data-waitlist-container>
  <form class="waitlist-form" data-waitlist-form novalidate>
    <input
      class="waitlist-input transition-[background-color,border-color,box-shadow,outline-color] duration-300 [&[data-nav-highlight='true']]:!bg-zinc-100 [&[data-nav-highlight='true']]:!border-zinc-900 [&[data-nav-highlight='true']]:!outline [&[data-nav-highlight='true']]:!outline-2 [&[data-nav-highlight='true']]:!outline-solid [&[data-nav-highlight='true']]:!outline-zinc-400 [&[data-nav-highlight='true']]:!outline-offset-2 [&[data-nav-highlight='true']]:!ring-4 [&[data-nav-highlight='true']]:!ring-zinc-400/35 [&[data-nav-highlight='true']]:animate-pulse dark:[&[data-nav-highlight='true']]:!bg-zinc-900 dark:[&[data-nav-highlight='true']]:!border-cyan-300 dark:[&[data-nav-highlight='true']]:!outline-cyan-300 dark:[&[data-nav-highlight='true']]:!ring-cyan-300/30"
      name="email_address"
      aria-label="Email address"
      placeholder="Email address"
      required
      autocomplete="email"
      type="email"
    />

    <button class="waitlist-submit" type="submit" data-waitlist-submit>
      <span class="font-sans font-medium" data-waitlist-submit-label>Join Waitlist</span>
    </button>
  </form>

  <p class="waitlist-feedback" data-waitlist-feedback aria-live="polite"></p>
</div>

<script is:inline define:vars={{ waitlistApiUrl, successMessage, genericErrorMessage }}>
  (() => {
    const globalKey = "__mirageWaitlistSubmitBound";

    if (window[globalKey]) {
      return;
    }

    window[globalKey] = true;

    const endpoint = (waitlistApiUrl || "/api/waitlist").trim() || "/api/waitlist";

    const setFeedback = (container, status, message) => {
      const feedback = container.querySelector("[data-waitlist-feedback]");
      if (!(feedback instanceof HTMLElement)) {
        return;
      }

      feedback.dataset.status = status;
      feedback.textContent = message;
    };

    document.addEventListener("submit", async (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement) || !form.matches("[data-waitlist-form]")) {
        return;
      }

      event.preventDefault();

      const container = form.closest("[data-waitlist-container]");
      if (!(container instanceof HTMLElement)) {
        return;
      }

      const input = form.querySelector('input[name="email_address"]');
      if (!(input instanceof HTMLInputElement)) {
        return;
      }

      const submitButton = form.querySelector("[data-waitlist-submit]");
      const email = input.value.trim();

      if (!email) {
        setFeedback(container, "error", "Please enter your email.");
        input.focus();
        return;
      }

      const submitLabel =
        submitButton instanceof HTMLButtonElement
          ? submitButton.querySelector("[data-waitlist-submit-label]")
          : null;
      const previousText =
        submitLabel instanceof HTMLElement
          ? submitLabel.textContent
          : submitButton instanceof HTMLButtonElement
            ? submitButton.textContent
            : null;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      if (submitLabel instanceof HTMLElement) {
        submitLabel.textContent = "Submitting...";
      } else if (submitButton instanceof HTMLButtonElement) {
        submitButton.textContent = "Submitting...";
      }

      setFeedback(container, "idle", "");

      try {
        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            email,
            source: "marketing-site",
          }),
        });

        const payload = await response.json().catch(() => null);

        if (!response.ok) {
          const errorMessage =
            payload && typeof payload.error === "string"
              ? payload.error
              : genericErrorMessage;
          setFeedback(container, "error", errorMessage);
          return;
        }

        setFeedback(container, "success", successMessage);
        form.reset();
      } catch {
        setFeedback(container, "error", genericErrorMessage);
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }

        if (previousText) {
          if (submitLabel instanceof HTMLElement) {
            submitLabel.textContent = previousText;
          } else if (submitButton instanceof HTMLButtonElement) {
            submitButton.textContent = previousText;
          }
        }
      }
    });
  })();
</script>

<style>
  .waitlist-form-wrap {
    width: 100%;
    max-width: 48rem;
    margin-top: 2rem;
  }

  .waitlist-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    width: 100%;
  }

  .waitlist-input {
    min-width: 14rem;
    flex: 1 1 20rem;
    border: 1px solid rgb(227 227 227);
    background: rgb(255 255 255);
    font-size: 0.9375rem;
    line-height: 1.4;
    padding: 0.75rem;
    color: rgb(0 0 0);
  }

  .waitlist-input:focus {
    outline: none;
    border-color: rgb(82 82 82);
  }

  .waitlist-submit {
    border: 1px solid rgb(24 24 27);
    background: rgb(24 24 27);
    color: rgb(255 255 255);
    font-size: 0.9375rem;
    line-height: 1.4;
    padding: 0.75rem 1.5rem;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .waitlist-submit:hover {
    background: rgb(39 39 42);
  }

  .waitlist-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .waitlist-feedback {
    min-height: 1.5rem;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: rgb(82 82 91);
  }

  .waitlist-feedback[data-status="success"] {
    color: rgb(22 101 52);
  }

  .waitlist-feedback[data-status="error"] {
    color: rgb(185 28 28);
  }

  :global(.dark) .waitlist-input {
    border-color: rgb(63 63 70);
    background: rgb(15 15 16);
    color: rgb(250 250 250);
  }

  :global(.dark) .waitlist-input:focus {
    border-color: rgb(103 232 249);
  }

  :global(.dark) .waitlist-submit {
    border-color: rgb(245 245 245);
    background: rgb(245 245 245);
    color: rgb(10 10 10);
  }

  :global(.dark) .waitlist-submit:hover {
    background: rgb(255 255 255);
  }

  :global(.dark) .waitlist-feedback {
    color: rgb(212 212 216);
  }

  :global(.dark) .waitlist-feedback[data-status="success"] {
    color: rgb(74 222 128);
  }

  :global(.dark) .waitlist-feedback[data-status="error"] {
    color: rgb(252 165 165);
  }
</style>
