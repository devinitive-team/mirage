<section class="mt-16" id="how-it-works" aria-labelledby="flow-title">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px">
      <p
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-zinc-600 dark:text-zinc-300"
      >
        <span aria-hidden="true" class="h-px w-2.5 bg-zinc-400 dark:bg-zinc-500"></span>
        Workflow
        <span aria-hidden="true" class="h-px w-2.5 bg-zinc-400 dark:bg-zinc-500"></span>
      </p>
    </BlurFade>
    <BlurFade client:visible direction="up" offset={10} duration={0.5} blur="5px" delay={0.05}>
      <h2
        id="flow-title"
        class="mt-4 max-w-2xl font-display text-3xl leading-tight tracking-tight sm:text-4xl text-balance"
      >
        Three steps from upload to a defensible answer
      </h2>
    </BlurFade>
