---
import { BlurFade } from "@/components/ui/blur-fade";
---

<section class="mt-16" id="proof" aria-labelledby="proof-title">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px">
      <p
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-zinc-600 dark:text-zinc-300"
      >
        <span aria-hidden="true" class="h-px w-2.5 bg-zinc-400 dark:bg-zinc-500"></span>
        Why Mirage
        <span aria-hidden="true" class="h-px w-2.5 bg-zinc-400 dark:bg-zinc-500"></span>
      </p>
    </BlurFade>

    <BlurFade client:visible direction="up" offset={10} duration={0.5} blur="5px" delay={0.05}>
      <h2
        id="proof-title"
        class="mt-4 max-w-2xl font-display text-3xl leading-tight tracking-tight sm:text-4xl"
      >
        Built for everyone that cannot afford “probably right”
      </h2>
    </BlurFade>

    <div class="mt-8 border-y border-black/10 dark:border-white/15">
      <div class="grid md:grid-cols-2">
        <article class="py-6 md:pr-6">
          <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.1}>
            <div class="inline-flex items-center gap-2">
              <span aria-hidden="true" class="h-3 w-3 bg-cyan-500"></span>
              <span class="font-mono text-xs">01</span>
            </div>
            <h3 class="mt-3 font-display text-xl text-zinc-900 dark:text-zinc-100">Evidence first</h3>
            <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
              Every claim links to exact source pages, so audits and peer reviews take minutes, not
              hours.
            </p>
          </BlurFade>
        </article>

        <article class="border-t border-black/10 dark:border-white/15 py-6 md:border-l md:border-t-0 md:pl-6">
          <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.15}>
            <div class="inline-flex items-center gap-2">
              <span aria-hidden="true" class="h-3 w-3 bg-emerald-500"></span>
              <span class="font-mono text-xs">02</span>
            </div>
            <h3 class="mt-3 font-display text-xl text-zinc-900 dark:text-zinc-100">Higher answer precision</h3>
            <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
              Semantic retrieval follows meaning and document structure to reduce noise and improve
              relevance.
            </p>
          </BlurFade>
        </article>

        <article class="border-t border-black/10 dark:border-white/15 py-6 md:pr-6">
          <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.2}>
            <div class="inline-flex items-center gap-2">
              <span aria-hidden="true" class="h-3 w-3 bg-amber-500"></span>
              <span class="font-mono text-xs">03</span>
            </div>
            <h3 class="mt-3 font-display text-xl text-zinc-900 dark:text-zinc-100">Faster team adoption</h3>
            <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
              You and your team can ask natural-language questions immediately without building
              custom tagging systems or brittle rules.
            </p>
          </BlurFade>
        </article>

        <article class="border-t border-black/10 dark:border-white/15 py-6 md:border-l md:pl-6">
          <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.25}>
            <div class="inline-flex items-center gap-2">
              <span aria-hidden="true" class="h-3 w-3 bg-rose-500"></span>
              <span class="font-mono text-xs">04</span>
            </div>
            <h3 class="mt-3 font-display text-xl text-zinc-900 dark:text-zinc-100">Scales with your corpus</h3>
            <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
              Use the same workflow from first pilot to growing, organization-wide document libraries.
            </p>
          </BlurFade>
        </article>
      </div>
    </div>
  </div>
</section>
