---
import { BlurFade } from "@/components/ui/blur-fade";
---

<section class="mt-10 border-y border-black/10 dark:border-white/15 py-5" aria-label="Proof strip">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid divide-y divide-black/10 dark:divide-white/15 md:grid-cols-3 md:divide-x md:divide-y-0">
      <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px">
        <article class="py-4 md:px-4">
          <p class="mb-2 font-mono text-3xl tracking-tight sm:text-4xl">0 tags</p>
          <p class="pt-1 text-sm text-zinc-600 dark:text-zinc-300">No taxonomy project before first results</p>
        </article>
      </BlurFade>

      <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.08}>
        <article class="py-4 md:px-4">
          <p class="mb-2 font-mono text-3xl tracking-tight sm:text-4xl">1 query</p>
          <p class="pt-1 text-sm text-zinc-600 dark:text-zinc-300">One question searches every ready file in scope</p>
        </article>
      </BlurFade>

      <BlurFade client:visible direction="up" offset={8} duration={0.45} blur="4px" delay={0.16}>
        <article class="py-4 md:px-4">
          <p class="mb-2 font-mono text-3xl tracking-tight sm:text-4xl">Page-level</p>
          <p class="pt-1 text-sm text-zinc-600 dark:text-zinc-300">Evidence links make review fast and auditable</p>
        </article>
      </BlurFade>
    </div>
  </div>
</section>
