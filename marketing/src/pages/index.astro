---
import "../styles/global.css";

import { BorderBeam } from "@/components/ui/border-beam";
import { InteractiveGridPattern } from "@/components/ui/interactive-grid-pattern";
import { tryForFreeUrl } from "@/config/site";
import { buildTryForFreeUrl } from "@/lib/cta";

const pageTitle = "Mirage | Ask Documents Questions and Get Cited Answers";
const pageDescription =
  "Upload documents, ask in plain language, and get semantic answers backed by page-level citations your team can verify fast.";

const attributionParams = [
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_term",
  "utm_content",
  "gclid",
  "ref",
];

const ctaHref = buildTryForFreeUrl(tryForFreeUrl, Astro.url);

const containerClass =
  "mx-auto w-[min(1040px,calc(100%-2.6rem))] max-[720px]:w-[min(1040px,calc(100%-1.2rem))]";

const eyebrowClass =
  "m-0 inline-flex items-center gap-[0.4rem] font-mono text-[0.76rem] uppercase tracking-[0.08em] text-[color-mix(in_oklab,var(--text-1)_80%,var(--text-0)_20%)] before:h-px before:w-[10px] before:bg-[color-mix(in_oklab,var(--text-1)_40%,transparent_60%)] before:content-[''] after:h-px after:w-[10px]  after:content-['']";

const sectionClass =
  "mt-[clamp(3rem,8vw,6.2rem)] motion-safe:animate-in motion-safe:fade-in motion-safe:slide-in-from-bottom-3 motion-safe:duration-500";

const buttonBaseClass =
  "inline-flex min-h-11 items-center justify-center border border-transparent px-[1.15rem] py-[0.62rem] font-display text-[0.92rem] font-bold tracking-[0.004em] transition duration-150 ease-out hover:-translate-y-px focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color-mix(in_oklab,var(--accent-cyan)_60%,var(--text-0)_40%)]";

const buttonPrimaryClass = `${buttonBaseClass} border-[#111820] bg-[linear-gradient(180deg,#1d2835_0%,#111820_100%)] text-[#f8fafb] hover:bg-[linear-gradient(180deg,#1a3545_0%,#10161d_100%)]`;

const buttonSecondaryClass = `${buttonBaseClass} border-[var(--line-0)] bg-[color-mix(in_oklab,var(--surface-1)_88%,white_12%)] text-[var(--text-0)] hover:border-[var(--line-1)] hover:bg-white`;

const buttonCompactClass = `${buttonPrimaryClass} min-h-[38px] px-[0.95rem] py-[0.46rem] text-[0.84rem]`;

const sectionTitleClass =
  "mt-4 max-w-[20ch] font-display text-[clamp(1.4rem,3.2vw,2.35rem)] leading-[1.08] tracking-[-0.02em]";

const sectionIntroClass = "mt-[1.25rem] max-w-[66ch] text-[var(--text-1)] leading-[1.7]";

const heroImageFrameClass =
  "relative mt-8 border border-[color-mix(in_oklab,var(--line-1)_74%,var(--accent-cyan)_26%)] bg-[linear-gradient(180deg,color-mix(in_oklab,var(--surface-1)_76%,white_24%)_0%,color-mix(in_oklab,var(--surface-1)_94%,var(--accent-cyan-soft)_6%)_100%)] p-[clamp(0.34rem,0.9vw,0.68rem)] motion-safe:animate-in motion-safe:fade-in motion-safe:slide-in-from-bottom-2 motion-safe:duration-500";

const heroImageClass =
  "block h-[clamp(260px,44vw,520px)] w-full object-cover object-top [filter:contrast(1.04)_saturate(1.06)]";

const heroImageBeamFrameClass =
  "relative overflow-hidden border border-[color-mix(in_oklab,var(--line-1)_78%,transparent)]";

const heroImageAccentClass =
  "pointer-events-none absolute inset-x-[9%] -top-px h-px bg-[color-mix(in_oklab,var(--accent-cyan)_58%,transparent)]";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>

  <body>
    <header
      class="sticky top-0 z-40 border-b border-[color-mix(in_oklab,var(--line-0)_88%,transparent)] bg-[color-mix(in_oklab,var(--surface-1)_78%,transparent)] backdrop-blur-[10px]"
    >
      <div
        class={`${containerClass} flex min-h-[82px] items-center justify-between gap-4 max-[720px]:min-h-[72px]`}
      >
        <a
          href="/"
          class="inline-flex items-center gap-[0.52rem] font-display text-[1.26rem] font-extrabold tracking-[0.01em]"
          aria-label="Mirage home"
        >
          <svg viewBox="0 0 32 32" aria-hidden="true" class="h-[1.6rem] w-[1.6rem] shrink-0">
            <path d="M5 24.5L9.1 8h3.8L8.8 24.5H5Z" fill="currentColor"></path>
            <path d="M12.2 24.5L16 11.5h3.7L16 24.5h-3.8Z" fill="currentColor"></path>
            <path d="M19.6 24.5L23.7 8H27l-4 16.5h-3.4Z" fill="currentColor"></path>
          </svg>
          <span>Mirage</span>
        </a>
        <nav class="inline-flex items-center gap-[1.05rem] max-[720px]:hidden" aria-label="Primary">
          <a
            href="#how-it-works"
            class="text-[0.9rem] text-[var(--text-1)] transition-colors duration-[160ms] ease-out hover:text-[var(--text-0)]"
            >How it works</a
          >
          <a
            href="#proof"
            class="text-[0.9rem] text-[var(--text-1)] transition-colors duration-[160ms] ease-out hover:text-[var(--text-0)]"
            >Proof</a
          >
          <a
            href="#faq"
            class="text-[0.9rem] text-[var(--text-1)] transition-colors duration-[160ms] ease-out hover:text-[var(--text-0)]"
            >FAQ</a
          >
        </nav>
        <a
          href={ctaHref}
          class={buttonCompactClass}
          data-cta="try-for-free"
          data-cta-location="nav"
        >
          Try for free
        </a>
      </div>
    </header>

    <main class={`${containerClass} pb-[clamp(4.5rem,8vw,7.5rem)] pt-[clamp(1.8rem,4vw,3.1rem)]`}>
      <section class="mt-[1.4rem] flex items-stretch" id="top">
        <div class="min-w-0">
          <p class={eyebrowClass}>Ask any document. Verify every answer.</p>
          <h1 class="mt-[0.86rem] font-display text-[clamp(2rem,5.6vw,4rem)] leading-[1.02]">
            Find what matters across thousands of pages, with citations.
          </h1>
          <p
            class="mt-[1.4rem] max-w-[60ch] text-[clamp(1rem,1.4vw,1.16rem)] leading-[1.7] text-[var(--text-1)]"
          >
            Mirage turns raw PDFs into semantic context so your team can ask in plain language and
            get answers tied to exact source pages.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-[0.72rem]">
            <a
              href={ctaHref}
              class={buttonPrimaryClass}
              data-cta="try-for-free"
              data-cta-location="hero"
            >
              Try for free
            </a>
            <a href="#how-it-works" class={buttonSecondaryClass}>See how Mirage works</a>
          </div>
          <div class={heroImageFrameClass + heroImageBeamFrameClass}>
            <span aria-hidden="true" class={heroImageAccentClass}></span>
            <img
              src="/hero.png"
              alt="Mirage product preview with cited answers and document context"
              class={heroImageClass}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
            <BorderBeam
              client:load
              size={210}
              duration={7.5}
              borderWidth={2}
              colorFrom="#fff"
              colorTo="#000"
              className="opacity-60"
            />
          </div>
        </div>
      </section>

      <section
        class="mt-[clamp(2.3rem,4vw,3.3rem)] border-y border-[var(--line-0)] py-[1.3rem]"
        aria-label="Proof strip"
      >
        <div
          class="flex flex-col divide-y divide-[var(--line-0)] min-[981px]:flex-row min-[981px]:divide-x min-[981px]:divide-y-0"
        >
          <article class="py-[0.92rem] min-[981px]:flex-1 min-[981px]:px-4">
            <p class="font-display text-[clamp(1.32rem,3vw,2.1rem)] tracking-[-0.02em]">0 tags</p>
            <p class="pt-[0.2rem] text-[0.86rem] text-[var(--text-1)]">
              No taxonomy project before first results
            </p>
          </article>
          <article class="py-[0.92rem] min-[981px]:flex-1 min-[981px]:px-4">
            <p class="font-display text-[clamp(1.32rem,3vw,2.1rem)] tracking-[-0.02em]">1 query</p>
            <p class="pt-[0.2rem] text-[0.86rem] text-[var(--text-1)]">
              One question searches every ready file in scope
            </p>
          </article>
          <article class="py-[0.92rem] min-[981px]:flex-1 min-[981px]:px-4">
            <p class="font-display text-[clamp(1.32rem,3vw,2.1rem)] tracking-[-0.02em]">
              Page-level
            </p>
            <p class="pt-[0.2rem] text-[0.86rem] text-[var(--text-1)]">
              Evidence links make review fast and auditable
            </p>
          </article>
        </div>
      </section>

      <section class={sectionClass} id="how-it-works" aria-labelledby="flow-title">
        <p class={eyebrowClass}>Workflow</p>
        <h2 id="flow-title" class={sectionTitleClass}>
          Three steps from upload to a defensible answer
        </h2>
        <p class={sectionIntroClass}>
          Start with real files, ask a real question, and trace each answer back to the source
          before anyone acts on it.
        </p>
        <ol
          class="mt-[1.8rem] grid grid-cols-1 gap-y-[1.35rem] min-[981px]:grid-cols-3 min-[981px]:gap-x-[1.35rem]"
        >
          <li class="relative border-l border-[var(--line-0)] pl-[1.1rem]">
            <span
              aria-hidden="true"
              class="absolute left-[-5px] top-[0.35rem] h-[9px] w-[9px] bg-black"></span>
            <p class="m-0 font-mono text-[0.8rem] text-black">01 · Ingest</p>

            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 400 400"
              width="100%"
              height="100%"
            >
              <defs>
                <style>
                  .bg-grid {
                    stroke: currentColor;
                    stroke-width: 0.5;
                    stroke-dasharray: 2 6;
                    opacity: 0.15;
                  }
                  .axes {
                    stroke: currentColor;
                    stroke-width: 0.75;
                    stroke-dasharray: 4 4;
                    opacity: 0.35;
                  }
                  .wireframe {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 1.5;
                    stroke-linejoin: round;
                    stroke-linecap: round;
                  }
                  .details {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 0.75;
                    stroke-linejoin: round;
                    stroke-linecap: round;
                    opacity: 0.8;
                  }
                  .nodes {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 1;
                    opacity: 0.9;
                  }
                  .highlight {
                    stroke-width: 1.75;
                  }
                </style>
              </defs>

              <g class="bg-grid">
                <path
                  d="M 0,200 L 400,0 M 0,250 L 400,50 M 0,300 L 400,100 M 0,350 L 400,150 M 0,400 L 400,200"
                ></path>
                <path
                  d="M 400,200 L 0,0 M 400,250 L 0,50 M 400,300 L 0,100 M 400,350 L 0,150 M 400,400 L 0,200"
                ></path>
                <path d="M 100,0 L 100,400 M 200,0 L 200,400 M 300,0 L 300,400"></path>
              </g>

              <g class="axes">
                <path d="M 200,320 L 300,270 L 210,225 L 110,275 Z"></path>
                <path
                  d="M 200,280 L 200,320 M 300,230 L 300,270 M 110,235 L 110,275 M 210,155 L 210,225"
                ></path>
                <path d="M 200,280 L 350,205"></path>
                <path d="M 200,280 L 50,205"></path>
                <path d="M 200,280 L 200,60"></path>
              </g>

              <g class="wireframe">
                <path d="M 110,205 L 110,235"></path>
                <path d="M 200,250 L 200,280"></path>
                <path d="M 300,200 L 300,230"></path>

                <path d="M 110,235 L 200,280 L 300,230"></path>
                <path d="M 110,229 L 200,274 L 300,224"></path>
                <path d="M 110,223 L 200,268 L 300,218"></path>
                <path d="M 110,217 L 200,262 L 300,212"></path>
                <path d="M 110,211 L 200,256 L 300,206"></path>
              </g>

              <g class="wireframe">
                <path d="M 200,250 L 300,200 L 228,164 L 190,165 L 110,205 Z"></path>
                <path d="M 190,165 L 208,174 L 228,164"></path>
                <path d="M 190,165 L 228,164" class="details" stroke-dasharray="2 2"></path>
              </g>

              <g class="wireframe highlight">
                <path d="M 138,209 L 165,222.5"></path>
                <path d="M 138,209 L 158,199 L 171.5,205.75 L 151.5,215.75"></path>
                <path d="M 168,194 L 195,207.5"></path>
                <path d="M 168,194 L 183,186.5 L 201.5,190.75 L 210,200 L 195,207.5"></path>
                <path d="M 198,179 L 225,192.5"></path>
                <path d="M 198,179 L 218,169"></path>
                <path d="M 211.5,185.75 L 226.5,178.25"></path>
              </g>

              <g class="details">
                <path d="M 178.5,229.25 L 238.5,199.25"></path>
                <path d="M 187.5,233.75 L 257.5,198.75"></path>
                <path d="M 196.5,238.25 L 246.5,213.25"></path>
              </g>

              <g class="nodes">
                <circle cx="200" cy="250" r="2.5"></circle>
                <circle cx="300" cy="200" r="2.5"></circle>
                <circle cx="110" cy="205" r="2.5"></circle>
                <circle cx="190" cy="165" r="2.5"></circle>
                <circle cx="228" cy="164" r="2.5"></circle>
                <circle cx="208" cy="174" r="2.5"></circle>

                <circle cx="200" cy="280" r="2.5"></circle>
                <circle cx="300" cy="230" r="2.5"></circle>
                <circle cx="110" cy="235" r="2.5"></circle>

                <circle cx="138" cy="209" r="1.5"></circle>
                <circle cx="168" cy="194" r="1.5"></circle>
                <circle cx="198" cy="179" r="1.5"></circle>
              </g>

              <g class="details">
                <path d="M 110,205 L 85,192.5"></path>
                <path d="M 110,235 L 85,222.5"></path>
                <path d="M 90,195 L 90,225" stroke-width="1"></path>
                <path d="M 86,195 L 94,195" stroke-width="1.5"></path>
                <path d="M 86,225 L 94,225" stroke-width="1.5"></path>
              </g>
            </svg>
            <h3 class="mt-[0.66rem] font-display text-[1.05rem] tracking-[-0.01em]">
              Ingest documents
            </h3>
            <p class="mt-[0.72rem] text-[var(--text-1)] leading-[1.65]">
              Drop in PDFs and let background processing extract document structure while your team
              keeps moving.
            </p>
          </li>
          <li class="relative border-l border-[var(--line-0)] pl-[1.1rem]">
            <span
              aria-hidden="true"
              class="absolute left-[-5px] top-[0.35rem] h-[9px] w-[9px] bg-black"></span>
            <p class="m-0 font-mono text-[0.8rem] text-black">02 · Retrieve</p>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 500 500"
              width="100%"
              height="100%"
            >
              <defs>
                <style>
                  /* Core styles for the technical wireframe aesthetic */
                  .bg-axis {
                    stroke: currentColor;
                    stroke-width: 0.5;
                    stroke-dasharray: 2 8;
                    opacity: 0.2;
                  }
                  .plane-edge {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 1;
                    stroke-linejoin: round;
                    opacity: 0.4;
                  }
                  .plane-fill {
                    fill: currentColor;
                    opacity: 0.02;
                  }
                  .grid-line {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 0.5;
                    stroke-dasharray: 4 4;
                    opacity: 0.3;
                  }
                  .semantic-link-solid {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 1.25;
                    stroke-linecap: round;
                    opacity: 0.9;
                  }
                  .semantic-link-dashed {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 1;
                    stroke-dasharray: 3 4;
                    opacity: 0.7;
                  }
                  .projection-line {
                    fill: none;
                    stroke: currentColor;
                    stroke-width: 0.5;
                    stroke-dasharray: 1 3;
                    opacity: 0.5;
                  }
                  .node {
                    fill: var(--bg-color, #fff);
                    stroke: currentColor;
                    stroke-width: 1.5;
                  }
                  .node-inner {
                    fill: currentColor;
                  }
                  .tech-text {
                    font-family: monospace;
                    font-size: 8px;
                    fill: currentColor;
                    opacity: 0.6;
                    letter-spacing: 1px;
                  }
                  .accent {
                    stroke-width: 1.5;
                    opacity: 1;
                  }
                </style>
              </defs>

              <g class="bg-axis">
                <path d="M 250,0 L 250,500"></path>
                <path d="M 0,125 L 500,375"></path>
                <path d="M 0,375 L 500,125"></path>
              </g>

              <g class="projection-line">
                <path d="M 110,160 L 110,320"></path>
                <path d="M 390,160 L 390,320"></path>
                <path d="M 250,90 L 250,250"></path>
                <path d="M 250,230 L 250,390"></path>
              </g>

              <g>
                <polygon points="250,250 390,320 250,390 110,320" class="plane-fill"></polygon>
                <polygon points="250,250 390,320 250,390 110,320" class="plane-edge"></polygon>

                <path d="M 156.6,273.3 L 296.6,203.3" class="grid-line"></path>
                <path d="M 203.3,296.6 L 343.3,226.6" class="grid-line"></path>
                <path d="M 156.6,343.3 L 296.6,273.3" class="grid-line"></path>
                <path d="M 203.3,366.6 L 343.3,296.6" class="grid-line"></path>

                <circle cx="180" cy="330" r="3" class="node"></circle>
                <circle cx="273" cy="285" r="3" class="node"></circle>
                <circle cx="320" cy="330" r="3" class="node"></circle>

                <text
                  x="360"
                  y="380"
                  class="tech-text"
                  transform="matrix(0.866, 0.5, -0.866, 0.5, 230, -50)">L3: DATA_INDEX</text
                >
              </g>

              <g>
                <polygon points="250,170 390,240 250,310 110,240" class="plane-fill"></polygon>
                <polygon points="250,170 390,240 250,310 110,240" class="plane-edge"></polygon>

                <g class="grid-line">
                  <path d="M 138,226 L 278,156"></path>
                  <path d="M 166,240 L 306,170"></path>
                  <path d="M 194,254 L 334,184"></path>
                  <path d="M 222,268 L 362,198"></path>
                  <path d="M 138,254 L 278,324"></path>
                  <path d="M 166,240 L 306,310"></path>
                  <path d="M 194,226 L 334,296"></path>
                  <path d="M 222,212 L 362,282"></path>
                </g>

                <ellipse
                  cx="250"
                  cy="240"
                  rx="60"
                  ry="30"
                  class="grid-line"
                  style="stroke-dasharray: 2 4; opacity: 0.6;"></ellipse>

                <circle cx="210" cy="220" r="4" class="node"></circle>
                <circle cx="250" cy="240" r="2.5" class="node"></circle>
                <circle cx="290" cy="260" r="4" class="node"></circle>
                <circle cx="300" cy="215" r="3" class="node"></circle>

                <path d="M 215,220 L 235,220" class="projection-line"></path>
                <text x="240" y="222" class="tech-text">[0.82, -0.14, ...]</text>

                <text
                  x="360"
                  y="300"
                  class="tech-text"
                  transform="matrix(0.866, 0.5, -0.866, 0.5, 230, -130)">L2: EMBEDDING_SPACE</text
                >
              </g>

              <g>
                <polygon points="250,90 390,160 250,230 110,160" class="plane-fill"></polygon>
                <polygon points="250,90 390,160 250,230 110,160" class="plane-edge"></polygon>

                <path d="M 180,125 L 320,195" class="grid-line" style="opacity: 0.5;"></path>
                <path d="M 180,195 L 320,125" class="grid-line" style="opacity: 0.5;"></path>

                <circle cx="250" cy="160" r="8" class="node accent"></circle>
                <circle cx="250" cy="160" r="3" class="node-inner"></circle>

                <path d="M 250,70 L 250,140" class="semantic-link-solid"></path>
                <polyline points="245,130 250,142 255,130" class="semantic-link-solid"></polyline>

                <text
                  x="360"
                  y="220"
                  class="tech-text"
                  transform="matrix(0.866, 0.5, -0.866, 0.5, 230, -210)">L1: QUERY_VECTOR</text
                >
              </g>

              <g>
                <path d="M 250,160 L 210,220" class="semantic-link-solid"></path>
                <path d="M 250,160 L 290,260" class="semantic-link-solid"></path>
                <path d="M 250,160 L 300,215" class="semantic-link-solid"></path>

                <path
                  d="M 210,220 Q 250,260 290,260"
                  class="semantic-link-dashed"
                  style="stroke-dasharray: 2 4;"></path>
                <path d="M 250,240 L 290,260" class="semantic-link-dashed"></path>

                <path d="M 210,220 L 180,330" class="semantic-link-dashed"></path>
                <path d="M 290,260 L 273,285" class="semantic-link-dashed"></path>
                <path d="M 290,260 L 320,330" class="semantic-link-dashed"></path>
              </g>

              <g class="plane-edge" style="stroke-width: 0.75; opacity: 0.8;">
                <path d="M 105,160 L 115,160 M 110,155 L 110,165"></path>
                <path d="M 385,160 L 395,160 M 390,155 L 390,165"></path>
                <path d="M 105,240 L 115,240 M 110,235 L 110,245"></path>
                <path d="M 385,240 L 395,240 M 390,235 L 390,245"></path>
                <path d="M 105,320 L 115,320 M 110,315 L 110,325"></path>
                <path d="M 385,320 L 395,320 M 390,315 L 390,325"></path>
              </g>
            </svg>
            <h3 class="mt-[0.66rem] font-display text-[1.05rem] tracking-[-0.01em]">
              Build semantic index
            </h3>
            <p class="mt-[0.72rem] text-[var(--text-1)] leading-[1.65]">
              Mirage organizes content by meaning, so questions are matched to relevant sections
              instead of loose keyword hits.
            </p>
          </li>
          <li class="relative border-l border-[var(--line-0)] pl-[1.1rem]">
            <span
              aria-hidden="true"
              class="absolute left-[-5px] top-[0.35rem] h-[9px] w-[9px] bg-black"></span>
            <p class="m-0 font-mono text-[0.8rem] text-black">03 · Verify</p>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 500 500"
              width="100%"
              height="100%"
            >
              <defs>
                <style>
                  /* Core styles for the technical wireframe aesthetic */
                  .frame {
                    stroke: currentColor;
                    stroke-width: 0.5;
                    fill: none;
                    opacity: 0.3;
                  }
                  .bg-grid {
                    stroke: currentColor;
