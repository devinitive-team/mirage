---
import "../styles/global.css";

import FaqSection from "@/components/landing/faq-section.astro";
import FinalCtaSection from "@/components/landing/final-cta-section.astro";
import HeroSection from "@/components/landing/hero-section.astro";
import ProofSection from "@/components/landing/proof-section.astro";
import ProofStripSection from "@/components/landing/proof-strip-section.astro";
import SiteHeader from "@/components/landing/site-header.astro";
import WorkflowSection from "@/components/landing/workflow-section.astro";
import SiteFooter from "@/components/landing/site-footer.astro";
import { tryForFreeUrl } from "@/config/site";
import { buildTryForFreeUrl } from "@/lib/cta";

const pageTitle = "Mirage | Ask Documents Questions and Get Cited Answers";
const pageDescription =
  "Upload documents, ask in plain language, and get semantic answers backed by page-level citations your team can verify fast.";

const attributionParams = [
  "utm_source",
  "utm_medium",
  "utm_campaign",
  "utm_term",
  "utm_content",
  "gclid",
  "ref",
];

const ctaHref = buildTryForFreeUrl(tryForFreeUrl, Astro.url);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
  </head>

  <body>
    <SiteHeader ctaHref={ctaHref} />

    <main class="pb-20 pt-8 md:pt-12">
      <HeroSection ctaHref={ctaHref} />
      <ProofStripSection />
      <WorkflowSection />
      <ProofSection />
      <FaqSection />
      <FinalCtaSection ctaHref={ctaHref} />
    </main>

    <SiteFooter />

    <script is:inline define:vars={{ attributionParams }}>
      (() => {
        const focusHeroWaitlistInput = () => {
          const emailInput = document.querySelector('#top input[name="email_address"]');
          if (!(emailInput instanceof HTMLInputElement)) return false;

          emailInput.scrollIntoView({ behavior: "smooth", block: "center" });
          emailInput.removeAttribute("data-nav-highlight");
          // Force restart of the highlight animation for repeated clicks.
          void emailInput.offsetWidth;
          emailInput.setAttribute("data-nav-highlight", "true");

          window.setTimeout(() => {
            emailInput.focus({ preventScroll: true });
          }, 220);

          window.setTimeout(() => {
            emailInput.removeAttribute("data-nav-highlight");
          }, 1800);

          return true;
        };

        document.querySelectorAll('a[data-cta-location="nav"]').forEach((anchor) => {
          anchor.addEventListener("click", (event) => {
            if (focusHeroWaitlistInput()) {
              event.preventDefault();
            }
          });
        });

        const search = new URLSearchParams(window.location.search);

        const hasAttribution = attributionParams.some((key) => search.has(key));
        if (!hasAttribution) return;

        document.querySelectorAll('a[data-cta="try-for-free"]').forEach((anchor) => {
          const href = anchor.getAttribute("href");
          if (!href) return;

          try {
            const destination = new URL(href, window.location.origin);

            attributionParams.forEach((key) => {
              const values = search.getAll(key);
              if (values.length === 0) return;

              destination.searchParams.delete(key);
              values.forEach((value) => destination.searchParams.append(key, value));
            });

            anchor.setAttribute("href", destination.toString());
          } catch {
            // Keep original href when URL parsing fails.
          }
        });
      })();
    </script>
  </body>
</html>
